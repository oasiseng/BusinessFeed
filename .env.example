# API
PORT=4317
HOST=127.0.0.1
BUSINESSFEED_DB_PATH=./data/businessfeed.sqlite
WEBHOOK_SECRET=replace-with-long-random-secret
ALLOW_UNSIGNED_WEBHOOKS=false
APP_ORIGIN=http://127.0.0.1:4317
ALLOWED_ORIGINS=http://127.0.0.1:4317,http://localhost:4317,http://127.0.0.1:5173,http://localhost:5173

# Web
# Leave empty for same-origin production hosting.
VITE_API_BASE_URL=

# Optional Trello read-only adapter
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_QUERY=board:Projects

# Optional Microsoft Graph / Outlook read-only adapter
OUTLOOK_GRAPH_TOKEN=
